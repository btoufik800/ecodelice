{
  "name": "ecodelices",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "ÉcoDélices — projet unifié React (Vite) + backend Node/Express + MySQL",
  "scripts": {
    "install:all": "npm install && npm --prefix server install",
    "dev:client": "vite",
    "dev:server": "node --watch server/server.js",
    "dev": "concurrently -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/server.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "vite": "^5.0.0"
  }
}
